# Frontend — safe to expose. Leave blank for fully static demo mode.
VITE_API_BASE_URL=

# Server-side only. Never prefix with VITE_ — these would otherwise be bundled
# into the static frontend.
AIRTABLE_TOKEN=
# Alias accepted by the API: AIRTABLE_API_KEY (use either, not both).
AIRTABLE_BASE_ID=

# Optional: override default table names if your Airtable base uses different
# labels. Defaults match the Airtable setup documented in the README.
AIRTABLE_COACHES_TABLE=Coaches
AIRTABLE_PLAYERS_TABLE=Players
AIRTABLE_PARENTS_TABLE=Parents/Guardians
AIRTABLE_MEDIA_CONSENTS_TABLE=Media Consents
AIRTABLE_SESSIONS_TABLE=Sessions
AIRTABLE_ATTENDANCE_TABLE=Attendance
AIRTABLE_QR_CHECKINS_TABLE=QR Check-ins

# Optional Airtable filterByFormula for selecting the active coach record.
AIRTABLE_COACH_FILTER=
